# syntax=docker/dockerfile:1
[[if eq .JavaBuildTool "gradle"]]FROM gradle:8-jdk21 AS build
WORKDIR /src
COPY . .
RUN gradle --no-daemon clean bootJar -x test || gradle --no-daemon clean build -x test
[[else]]FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /src
COPY pom.xml ./
RUN mvn -q -e -B dependency:go-offline
COPY . .
RUN mvn -q -e -B clean package -DskipTests
[[end]]
FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=build /src/[[if eq .JavaBuildTool "gradle"]]build/libs[[else]]target[[end]]/*.jar app.jar
EXPOSE [[.Port]]
ENTRYPOINT ["java", "-jar", "app.jar"]
